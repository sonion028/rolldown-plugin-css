{
  "name": "rolldown-plugin-css",
  "version": "0.0.1",
  "description": "Rolldown CSS plugin: Sass/Scss/Less compilation, CSS Modules & compatibility via Lightning CSS, auto-injecting CSS imports into JS.",
  "type": "module",
  "module": "dist/index.esm.js",
  "types": "dist/types/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "lint": "eslint '{src,apps,packages}/**/*.{ts,tsx,js,jsx,vue}'",
    "lint:fix": "eslint '{src,apps,packages}/**/*.{ts,tsx,js,jsx,vue}' --fix",
    "lint:error": "eslint '{src,apps,packages}/**/*.{ts,tsx,js,jsx,vue}' --quiet",
    "lint:spell": "cspell lint '{src,apps,packages}/**/*.{js,ts,jsx,tsx,mjs,cjs,json,css,less,scss,vue,html,md}'",
    "fmt": "oxfmt '{src,packages,apps}/**/*.*'",
    "fmt:check": "oxfmt --check '{src,packages,apps}/**/*.*'",
    "preinstall": "npm run sync:node-version && (npx -y only-allow pnpm || exit 1)",
    "prepare": "npx simple-git-hooks",
    "sync:node-version": "node scripts/sync-node-version/index.js"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.32.1"
  },
  "peerDependencies": {
    "lightningcss": "^1.32.0",
    "less": "^4.6.4",
    "sass": "^1.98.0",
    "sass-embedded": "^1.98.0",
    "rolldown": ">=1.0.0-rc.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/less": "^3.0.8",
    "@types/node": "^25.5.0",
    "cspell": "^9.7.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.8.0",
    "globals": "^17.4.0",
    "less": "^4.6.4",
    "lightningcss": "^1.32.0",
    "lint-staged": "^16.4.0",
    "only-allow": "^1.2.2",
    "oxfmt": "^0.41.0",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.0-rc.10",
    "sass": "^1.98.0",
    "sass-embedded": "^1.98.0",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "keywords": [
    "rolldown-plugin",
    "rolldown",
    "css",
    "sass",
    "less",
    "lightningCSS"
  ],
  "author": "sonion",
  "license": "MIT",
  "repository": "https://github.com/sonion028/rolldown-plugin-css",
  "bugs": {
    "url": "https://github.com/sonion028/rolldown-plugin-css/issues"
  },
  "private": false,
  "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
  "compatiblePackages": {
    "schemaVersion": 1,
    "rolldown": {"type": "compatible", "versions": ">=1.0.0-rc.9"},
    "vite": { "type": "compatible", "versions": "^7.0.0 || ^8.0.0" },
    "rollup": {"type": "unknown"}
  }
}